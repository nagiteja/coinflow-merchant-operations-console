# Coinflow simulator -> merchant webhook receiver configuration
#
# These env vars are read by the provider simulator (webhook signing) and the merchant receiver (signature verification).

# Shared secret for webhook verification.
# - If WEBHOOK_VERIFICATION_MODE=HMAC, it is used as the HMAC key.
# - If WEBHOOK_VERIFICATION_MODE=AUTH_HEADER, it is compared against Authorization: Bearer <secret>.
COINFLOW_WEBHOOK_SECRET=dev-secret-change-me

# Signature verification mode used by the merchant receiver.
# Allowed values: "HMAC" | "AUTH_HEADER"
WEBHOOK_VERIFICATION_MODE=HMAC

# Optional failure simulation for the merchant receiver.
# Allowed values: "NONE" | "TIMEOUT_ONCE" | "FAIL_500_RATE"
# NOTE: the UI scenarios also inject per-payment test controls via webhook payload.
MERCHANT_WEBHOOK_FAILURE_MODE=NONE

# Base URL so the simulator can POST webhooks to this same Next.js app.
# For Railway production, set to: https://<service-name>.railway.app
# For local dev: http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

